# Docker Compose Environment Variables
# Copy this file to .env and fill in real values before running `docker-compose up`

# JWT secrets for token signing (required)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your-64-byte-hex-access-secret-here
JWT_REFRESH_SECRET=your-64-byte-hex-refresh-secret-here

# MFA encryption key (required)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MFA_ENCRYPTION_KEY=your-32-byte-hex-mfa-key-here

# Note: For local development, you can also use the backend/.env file
# which has additional configuration options. See backend/.env.example for details.