# Copy to .env and fill in real values. Never commit .env.
DATABASE_URL="file:./dev.db"

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="7"

# 32-byte (64 hex char) key used to encrypt MFA secrets at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MFA_ENCRYPTION_KEY=""

# Frontend origins allowed by CORS
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

NODE_ENV="development"
PORT=4000

# Set to "true" to require a valid CAPTCHA token after N failed logins.
# In this reference implementation the captcha verifier is a stub -
# wire it to a real provider (e.g. hCaptcha/Turnstile) in production;
# see utils/captcha.js.
CAPTCHA_ENABLED="true"
