// Prisma schema for the Time-Bank Skill-Exchange platform.
// Dev uses SQLite for zero-config local running; swap provider to
// "postgresql" + DATABASE_URL for production (see README - production
// hardening section). Using a relational DB (not a document store) is a
// deliberate security-by-design choice: it gives us real ACID transactions
// for credit transfers, and foreign-key constraints prevent orphaned /
// spoofed references (a common source of IDOR bugs).

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  MEMBER
  MEDIATOR
  ADMIN
}

enum BookingStatus {
  REQUESTED
  ACCEPTED
  DECLINED
  COMPLETED
  DISPUTED
  CANCELLED
}

enum LedgerReason {
  BOOKING_COMPLETED
  DISPUTE_RESOLVED_CREDIT
  DISPUTE_RESOLVED_DEBIT
  SIGNUP_BONUS
  ADMIN_ADJUSTMENT
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  emailVerified       Boolean   @default(false)
  passwordHash        String
  passwordChangedAt   DateTime  @default(now())
  // Rolling history of previous password hashes (reuse prevention).
  passwordHistory     PasswordHistory[]
  role                Role      @default(MEMBER)

  // MFA (TOTP)
  mfaEnabled          Boolean   @default(false)
  mfaSecret           String?   // encrypted at rest, see utils/crypto.js
  mfaBackupCodes      String?   // JSON array of hashed backup codes

  // Account / brute-force protection
  failedLoginCount    Int       @default(0)
  lockedUntil         DateTime?

  // Profile
  displayName         String
  bio                 String?
  skillsOffered       String?   // JSON string array
  skillsNeeded        String?   // JSON string array
  isProfilePrivate    Boolean   @default(false)
  timeCredits         Int       @default(2) // small signup bonus

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  sessions            Session[]
  bookingsAsProvider  Booking[] @relation("ProviderBookings")
  bookingsAsRequester Booking[] @relation("RequesterBookings")
  ledgerEntries       LedgerEntry[]
  activityLogs        ActivityLog[]
  disputesRaised      Dispute[] @relation("DisputeRaisedBy")
  disputesMediated    Dispute[] @relation("DisputeMediatedBy")
}

model PasswordHistory {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hash      String
  createdAt DateTime @default(now())
}

// Server-side session record backing refresh tokens, enabling true
// server-side invalidation (logout / "log out all devices" / admin revoke)
// rather than relying purely on stateless JWT expiry.
model Session {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshHash   String   // hash of the refresh token, never store raw
  userAgent     String?
  ipAddress     String?
  createdAt     DateTime @default(now())
  expiresAt     DateTime
  revokedAt     DateTime?
}

model Booking {
  id            String        @id @default(uuid())
  providerId    String
  provider      User          @relation("ProviderBookings", fields: [providerId], references: [id])
  requesterId   String
  requester     User          @relation("RequesterBookings", fields: [requesterId], references: [id])
  skill         String
  hours         Int           @default(1)
  status        BookingStatus @default(REQUESTED)
  scheduledFor  DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  dispute       Dispute?
  ledgerEntries LedgerEntry[]
}

// Immutable, append-only ledger of every credit movement. Never updated or
// deleted - corrections happen via new offsetting entries. This is what
// lets us reconstruct "who had how many credits when" for audit purposes.
model LedgerEntry {
  id        String       @id @default(uuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  bookingId String?
  booking   Booking?     @relation(fields: [bookingId], references: [id])
  amount    Int          // positive = credit, negative = debit
  reason    LedgerReason
  createdAt DateTime     @default(now())
}

model Dispute {
  id           String    @id @default(uuid())
  bookingId    String    @unique
  booking      Booking   @relation(fields: [bookingId], references: [id])
  raisedById   String
  raisedBy     User      @relation("DisputeRaisedBy", fields: [raisedById], references: [id])
  reason       String
  mediatorId   String?
  mediator     User?     @relation("DisputeMediatedBy", fields: [mediatorId], references: [id])
  resolution   String?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
}

// Structured activity log for auditing / incident response. Deliberately
// avoids storing free-text bodies of user content or secrets - only
// metadata about the event (see utils/logger.js redaction rules).
model ActivityLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String   // e.g. "LOGIN_SUCCESS", "LOGIN_FAILED", "CREDIT_TRANSFER"
  targetType String?  // e.g. "Booking", "User"
  targetId   String?
  ipAddress  String?
  userAgent  String?
  metadata   String?  // JSON string, redacted of secrets
  createdAt  DateTime @default(now())
}
